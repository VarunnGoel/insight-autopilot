# For Streamlit Cloud deployment: copy this to ".streamlit/secrets.toml"
# (locally) or paste its contents into the app's Secrets box on
# share.streamlit.io -> Advanced settings -> Secrets.
#
# Never commit the real secrets.toml (it is in .gitignore).

KINTIO_API_KEY = "your-kintio-api-key-here"
CLAUDE_MODEL = "claude-opus-4"
